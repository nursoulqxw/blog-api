# Blog API — environment configuration template
# Copy this file to settings/.env and fill in real values.
# NEVER commit settings/.env to version control.

# Which settings module to load: local | prod
BLOG_ENV_ID=local

# Django secret key — change to a long random string in production
BLOG_SECRET_KEY='django-insecure-1m0hkdr)ih5)$e1stod%+p5n#zr%axlwn5+9#iv$9#5u)q7vel'

# Comma-separated list of allowed hosts (production only)
BLOG_ALLOWED_HOSTS=localhost,127.0.0.1

# Redis connection URL (used for caching, rate limiting, pub/sub)
# Use redis://redis:6379/0 when running inside Docker Compose
BLOG_REDIS_URL=redis://redis:6379/0

# Celery broker and result backend
BLOG_CELERY_BROKER_URL=redis://redis:6379/1
BLOG_CELERY_RESULT_BACKEND=redis://redis:6379/2

# Flower basic-auth credentials
BLOG_FLOWER_USER=admin
BLOG_FLOWER_PASSWORD=changeme

# JWT token lifetimes (integers)
BLOG_ACCESS_TOKEN_LIFETIME_MINUTES=60
BLOG_REFRESH_TOKEN_LIFETIME_DAYS=7

# Seed the database on container startup (true | false)
BLOG_SEED_DB=false

# PostgreSQL credentials (required in production, unused in local)
BLOG_DB_NAME=blog
BLOG_DB_USER=blog
BLOG_DB_PASSWORD=your-db-password-here
BLOG_DB_HOST=localhost
BLOG_DB_PORT=5432
